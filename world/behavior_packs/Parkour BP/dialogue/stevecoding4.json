{
  "format_version": "1.17",
  "minecraft:npc_dialogue": {
    "scenes": [
      {
        "scene_tag": "stevecoding4_intro",
        "npc_name": "§5스티브코딩",
        "text": "수고하셨어요.\n\n9개의 방을 전부 탈출하셨어요.\n§1정말 잘하셨어요.§r\n\n이 맵이 보여준 것들.\n이제 직접 만들어 볼 차례예요.",
        "buttons": [
          {
            "name": "이제 시작인가요?",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_hope"
            ]
          },
          {
            "name": "더 배우고 싶어요.",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_youtube"
            ]
          },
          {
            "name": "크리에이티브 모드로 전환",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_bye",
              "/gamemode creative @initiator"
            ]
          }
        ]
      },
      {
        "scene_tag": "stevecoding4_hope",
        "npc_name": "§5스티브코딩",
        "text": "이 튜토리얼을 끝내셨다면\n뭔가 얻어가신 게 있을 거예요.\n\n§1파쿠르§r, §5미로§r, §2방탈출§r.\n이 세 가지를 직접 경험하셨잖아요.\n\n이제 그 경험으로\n§1직접 만들어 보세요.§r\n좋은 작품을 기대할게요.",
        "buttons": [
          {
            "name": "← 돌아가기",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_intro"
            ]
          },
          {
            "name": "더 배우고 싶어요.",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_youtube"
            ]
          },
          {
            "name": "크리에이티브 모드로 전환",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_bye",
              "/gamemode creative @initiator"
            ]
          }
        ]
      },
      {
        "scene_tag": "stevecoding4_youtube",
        "npc_name": "§5스티브코딩",
        "text": "궁금한 게 생기면\n§1유튜브§r에서 찾아보세요.\n\n§5스티브코딩§r 채널이에요.\n\nyoutube.com/\n§2@stevecoding§r",
        "buttons": [
          {
            "name": "← 돌아가기",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_intro"
            ]
          },
          {
            "name": "크리에이티브 모드로 전환",
            "commands": [
              "/dialogue open @e[name=스티브코딩4,r=10] @initiator stevecoding4_bye",
              "/gamemode creative @initiator"
            ]
          }
        ]
      },
      {
        "scene_tag": "stevecoding4_bye",
        "npc_name": "§5스티브코딩",
        "text": "크리에이티브 모드예요.\n\n이제 이 맵을 §1자유롭게§r 둘러보세요.\n어떻게 만들었는지\n직접 확인해 보셔도 좋아요.\n\n§5좋은 맵 만드세요. 화이팅!§r",
        "buttons": []
      }
    ]
  }
