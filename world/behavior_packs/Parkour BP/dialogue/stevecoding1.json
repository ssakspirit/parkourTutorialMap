{
  "format_version": "1.17",
  "minecraft:npc_dialogue": {
    "scenes": [
      {
        "scene_tag": "stevecoding1_intro",
        "npc_name": "§5스티브코딩",
        "text": "안녕하세요. 저는 §5스티브코딩§r이에요.\n이 튜토리얼 월드의 제작자예요.\n\n맵을 만들면서\n지킨 §1제작 규칙§r들이 있어요.\n\n맵을 만들 예정이라면\n꼭 알아두세요.",
        "buttons": [
          {
            "name": "맵 크기 제한이 뭐예요?",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_rule1"
            ]
          },
          {
            "name": "출발 위치는 어떻게 설정해요?",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_rule2"
            ]
          },
          {
            "name": "그럼 이만.",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_bye"
            ]
          }
        ]
      },
      {
        "scene_tag": "stevecoding1_rule1",
        "npc_name": "§5스티브코딩",
        "text": "§1규칙 1 — 맵 크기 제한§r\n\n§5X, Z축§r 기준으로\n§164×64 블록§r 이내로 만들어야 해요.\n\n높이(§5Y축§r)는\n최대 §1200칸§r까지 가능해요.\n\n경계를 넘는 구조물이나\n장치는 허용되지 않아요.",
        "buttons": [
          {
            "name": "← 돌아가기",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_intro"
            ]
          },
          {
            "name": "출발 위치는 어떻게 설정해요?",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_rule2"
            ]
          },
          {
            "name": "그럼 이만.",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_bye"
            ]
          }
        ]
      },
      {
        "scene_tag": "stevecoding1_rule2",
        "npc_name": "§5스티브코딩",
        "text": "§1규칙 2 — 출발 위치 설정§r\n\n플레이어의 시작 위치는\n§5/setworldspawn§r 명령어로\n반드시 지정해야 해요.\n\n맵을 처음 열었을 때\n§1스타트 지점§r에 바로 등장해야 해요.\n\n빈 공간에서 시작되면 안 돼요.",
        "buttons": [
          {
            "name": "← 돌아가기",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_intro"
            ]
          },
          {
            "name": "맵 크기 제한이 뭐예요?",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_rule1"
            ]
          },
          {
            "name": "그럼 이만.",
            "commands": [
              "/dialogue open @e[name=스티브코딩1,r=10] @initiator stevecoding1_bye"
            ]
          }
        ]
      },
      {
        "scene_tag": "stevecoding1_bye",
        "npc_name": "§5스티브코딩",
        "text": "크기와 출발 위치.\n이 두 가지부터 잡아야\n§1맵 설계가 시작§r돼요.\n\n길을 따라가 보세요.",
        "buttons": []
      }
    ]
  }
}
