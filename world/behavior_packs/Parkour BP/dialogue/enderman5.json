          {
            "name": "퀴즈 도전!",
            "commands": ["/dialogue open @e[name=엔더맨5,r=10] @initiator enderman5_quiz"]
          },
          {
            "name": "그럼 이만.",
            "commands": ["/dialogue open @e[name=엔더맨5,r=10] @initiator enderman5_bye"]
          }
        ]
