            ]
          },
          {
            "name": "치트 방지는 어떻게 해요?",
            "commands": [
              "/dialogue open @e[name=스티브코딩3,r=10] @initiator stevecoding3_cheat"
            ]
          },
          {
            "name": "그럼 이만.",
            "commands": [
              "/dialogue open @e[name=스티브코딩3,r=10] @initiator stevecoding3_bye"
            ]
          }
        ]
      },
      {
        "scene_tag": "stevecoding3_sign",
        "npc_name": "§5스티브코딩",
        "text": "§1규칙 6 — 안내판 필수 배치§r\n\n스타트 지점에 팻말 또는 NPC로\n다음 내용을 담아야 해요.\n\n· §5맵 이름§r\n· §5제작자 이름§r\n· §5플레이 모드§r (협동 / 경쟁)\n· §5권장 인원§r\n· §5간단한 게임 소개§r",
        "buttons": [
          {
            "name": "← 돌아가기",
