{
  "format_version": "1.17",
  "minecraft:npc_dialogue": {
    "scenes": [

      {
        "scene_tag": "enderman2_intro",
        "npc_name": "§8엔더맨2",
        "text": "...죽어본 적 있어?\n\n파쿠르에서 떨어지면\n§c어딘가에서 다시 살아나지.§r\n\n그 §b리스폰 포인트§r,\n침대로 정할 수 있어.",
        "buttons": [
          {
            "name": "리스폰이 뭐야?",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_what"]
          },
          {
            "name": "침대로 어떻게 해?",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bed"]
          },
          {
            "name": "퀴즈 도전! 🧩",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_quiz"]
          },
          {
            "name": "그럼 이만. 👋",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bye"]
          }
        ]
      },

      {
        "scene_tag": "enderman2_what",
        "npc_name": "§8엔더맨2",
        "text": "죽으면... 어딘가로 돌아가잖아.\n그게 §b리스폰 포인트§r야.\n\n설정 안 하면 §c월드 시작 지점§r으로.\n설정하면 §a침대 위치§r로 돌아와.\n\n파쿠르엔 필수야.",
        "buttons": [
          {
            "name": "← 돌아가기",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_intro"]
          },
          {
            "name": "침대로 어떻게 해?",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bed"]
          },
          {
            "name": "그럼 이만. 👋",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bye"]
          }
        ]
      },

      {
        "scene_tag": "enderman2_bed",
        "npc_name": "§8엔더맨2",
        "text": "간단해.\n\n§a침대에 상호작용§r하면 돼.\n그러면 §b리스폰 포인트§r 설정 완료.\n\n...저기 침대 보여?\n직접 해봐. 말보다 몸이 먼저야.",
        "buttons": [
          {
            "name": "← 돌아가기",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_intro"]
          },
          {
            "name": "퀴즈 도전! 🧩",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_quiz"]
          },
          {
            "name": "그럼 이만. 👋",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bye"]
          }
        ]
      },

      {
        "scene_tag": "enderman2_quiz",
        "npc_name": "§8엔더맨2",
        "text": "...테스트야.\n\n침대로 §b리스폰 포인트§r를\n설정하려면 어떻게 해?",
        "buttons": [
          {
            "name": "침대 위에 서있어",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_wrong"]
          },
          {
            "name": "침대에 상호작용해",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_correct"]
          },
          {
            "name": "침대 옆에 블록을 놔",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_wrong"]
          },
          {
            "name": "그럼 이만. 👋",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bye"]
          }
        ]
      },

      {
        "scene_tag": "enderman2_correct",
        "npc_name": "§8엔더맨2",
        "text": "...맞아.\n\n§a침대에 상호작용§r하면\n§b리스폰 포인트§r가 설정돼.\n\n이제 저기 침대에 직접 해봐.\n죽어도 거기서 다시 살아날 거야.",
        "buttons": [
          {
            "name": "✓ 해볼게!",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_intro"]
          },
          {
            "name": "그럼 이만. 👋",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bye"]
          }
        ]
      },

      {
        "scene_tag": "enderman2_wrong",
        "npc_name": "§8엔더맨2",
        "text": "...틀렸어.\n\n그냥 서있거나 블록 놓는 건\n§c아무 의미 없어.§r\n\n§a침대에 상호작용§r해야\n리스폰 포인트가 설정돼.",
        "buttons": [
          {
            "name": "← 다시 보기",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bed"]
          },
          {
            "name": "퀴즈 다시!",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_quiz"]
          },
          {
            "name": "그럼 이만. 👋",
            "commands": ["/dialogue open @e[name=엔더맨2,r=10] @initiator enderman2_bye"]
          }
        ]
      },

      {
        "scene_tag": "enderman2_bye",
        "npc_name": "§8엔더맨2",
        "text": "...침대에 꼭 눕고 가.\n\n죽어서 처음부터 다시 하는 건\n나도 보기 싫거든.",
        "buttons": []
      }

    ]
  }
